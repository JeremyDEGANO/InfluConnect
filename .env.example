# ============================================================================
# InfluConnect — environment variables
# Copy this file to `.env` (at the repo root) and fill in your values.
# Docker Compose will pick them up automatically.
# ============================================================================

# ---- Django ----
SECRET_KEY=change-me-in-production-with-a-50-char-random-string
DEBUG=True
FERNET_KEY=                       # generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---- Database ----
DB_NAME=influconnect
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# ---- Email (SMTP) ----
# In dev, leave EMAIL_BACKEND on console to print emails to stdout.
# In prod, switch to SMTP backend and fill OVH/Brevo/SendGrid creds.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=                       # e.g. ssl0.ovh.net for OVH
EMAIL_PORT=587
EMAIL_HOST_USER=                  # e.g. noreply@yourdomain.fr
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=InfluConnect <noreply@influconnect.local>
ADMIN_NOTIFICATION_EMAILS=        # comma-separated list of admin emails to notify

# ---- Stripe (leave empty for stub mode — no real charges) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_COMMISSION_RATE=15       # percent

# ---- Frontend URL ----
FRONTEND_URL=http://localhost:5173
