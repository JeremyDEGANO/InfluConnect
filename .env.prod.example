# ---- Django ----
SECRET_KEY=replace-with-a-long-random-string
ALLOWED_HOSTS=influconnect.fr,www.influconnect.fr,backend
CSRF_TRUSTED_ORIGINS=https://influconnect.fr,https://www.influconnect.fr
FRONTEND_URL=https://influconnect.fr

# Fernet key used to encrypt OAuth / payment tokens.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-a-44-char-base64-urlsafe-fernet-key

# ---- Database ----
DB_NAME=influconnect
DB_USER=influconnect
DB_PASSWORD=replace-with-a-strong-password

# ---- Email (OVH / Postmark / SendGrid / Mailgun…) ----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=ssl0.ovh.net
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@influconnect.fr
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=InfluConnect <noreply@influconnect.fr>
ADMIN_NOTIFICATION_EMAILS=admin@influconnect.fr

# ---- Stripe (leave blank for stub mode) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_COMMISSION_RATE=15

# ---- Social OAuth (optional) ----
SOCIAL_OAUTH_REDIRECT_BASE=https://influconnect.fr
